# Copy this file to .env and fill in your keys
# .env is gitignored — never commit it

# Hugging Face token (required for gated models like Llama)
HF_TOKEN=hf_...

# OpenAI API key (required for GPT-4o — Tier 4)
OPENAI_API_KEY=sk-...

# Anthropic API key (required for Claude — Tier 4)
ANTHROPIC_API_KEY=sk-ant-...

# Weights & Biases API key (required for experiment tracking)
WANDB_API_KEY=...

# W&B project and entity
WANDB_PROJECT=toolfailbench
WANDB_ENTITY=your-wandb-username

# vLLM server URL (set this when running a local vLLM server for open-source models)
# Start server with: vllm serve <hf_model_id> --port 8000
VLLM_BASE_URL=http://localhost:8000/v1
